# ---------------------------------------------------------------------------
# CyberPet — environment variables
# Copy this file to .env and fill in values for your environment.
# .env is git-ignored; never commit real secrets.
# ---------------------------------------------------------------------------

# ---- Vite / Frontend -------------------------------------------------------

# Overrides the Vite dev server port (default: 1420, must match tauri.conf.json devUrl)
# VITE_DEV_PORT=1420

# Set to "true" to enable verbose tracker debug output in the browser console
# VITE_DEBUG_TRACKER=false

# ---- Tauri build -----------------------------------------------------------

# Code-signing identity for macOS notarisation (CI/staging builds)
# APPLE_CERTIFICATE=          # base64-encoded .p12 certificate
# APPLE_CERTIFICATE_PASSWORD= # password for the .p12
# APPLE_SIGNING_IDENTITY=     # e.g. "Developer ID Application: Acme Corp (XXXXXXXXXX)"
# APPLE_ID=                   # Apple ID email used for notarisation
# APPLE_PASSWORD=             # app-specific password for that Apple ID
# APPLE_TEAM_ID=              # Apple Developer Team ID

# ---- Face tracker (Python service) ----------------------------------------

# Camera device index passed to cv2.VideoCapture (default: 0 = built-in webcam)
# CYBERPET_CAMERA_INDEX=0

# Minimum MediaPipe face detection confidence (0.0–1.0, default: 0.5)
# CYBERPET_DETECTION_CONFIDENCE=0.5

# Minimum MediaPipe face tracking confidence (0.0–1.0, default: 0.5)
# CYBERPET_TRACKING_CONFIDENCE=0.5

# ---- Staging / CI ----------------------------------------------------------

# Target architecture for cross-compilation (e.g. aarch64-apple-darwin)
# TAURI_TARGET=

# Set by the Tauri CLI during builds; do not set manually
# TAURI_ENV=staging|production
