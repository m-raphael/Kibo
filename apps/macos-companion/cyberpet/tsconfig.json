{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@cyberpet/shared":          ["packages/shared/src/index.ts"],
      "@cyberpet/mascot-core":     ["packages/mascot-core/src/index.ts"],
      "@cyberpet/mascot-renderer": ["packages/mascot-renderer/src/index.ts"]
    }
  },
  "include": ["src", "vite.config.ts", "packages/*/src"]
}
